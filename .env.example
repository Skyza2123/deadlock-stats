DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/deadlock
DEADLOCK_API_KEY=replace-with-deadlock-api-key

# Local dev: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

STEAM_SECRET=replace-with-steam-web-api-key

# Optional credentials-login bootstrap user
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=replace-with-strong-password

# Optional: enable only when public/assets/heroes is populated
# 1 = prefer /assets/... static files
# 0 or unset = use /api/hero-images fallback (recommended default)
NEXT_PUBLIC_USE_EXTRACTED_HERO_ASSETS=0NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string
STEAM_SECRET=your-steam-web-api-key
